{
  "name": "@invocorder/recorder",
  "version": "2.0.0",
  "description": "Machine-action evidence substrate: hash-chained boundary records and replayable evidence bundles.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "bin": {
    "invocorder": "bin/invocorder.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "README.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md",
    "VERSION",
    "bin",
    "SECURITY.md",
    "PUBLISH_DECISION.md",
    "POWER_PLANE",
    "WORKSPACE_PERIMETER",
    "LOCAL_TOPOLOGY",
    "STACKED_PR_LEDGER",
    "STACK_TERMINALITY",
    "STACK_MERGE_READINESS"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/**/*.test.js || true",
    "release:check": "npm run build && npm test && npm run power:verify && npm run workspace:perimeter && npm run topology:verify && npm run stack:merge-readiness",
    "prepublish:gate": "node scripts/prepublish-gate.mjs",
    "verify:antimatterium": "node scripts/verify-antimatterium-profile.mjs",
    "power:verify": "node scripts/verify-npm-power-plane.mjs",
    "power:status": "node dist/src/cli/invocorder.js power-plane",
    "workspace:perimeter": "node scripts/verify-local-workspace-perimeter.mjs",
    "workspace:perimeter:local": "node scripts/verify-local-workspace-perimeter.mjs --require-local",
    "topology:verify": "node scripts/verify-local-topology-ledger.mjs",
    "stack:pr-ledger": "node scripts/verify-stacked-pr-ledger.mjs",
    "stack:terminality": "node scripts/verify-stack-terminality.mjs",
    "stack:merge-readiness": "node scripts/verify-stack-merge-readiness.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@antimatterium/antimatterium": "^0.2.2",
    "@kaaffilm/mk10-pro": "^1.0.3",
    "@verifrax/archicustos": "^0.1.1",
    "@verifrax/attestorium": "^0.1.1",
    "@verifrax/auctoriseal": "^0.1.5",
    "@verifrax/cicullis": "^0.1.3",
    "@verifrax/corpiform": "^0.1.7",
    "@verifrax/guillotine": "^0.1.1",
    "@verifrax/irrevocull": "^0.1.1",
    "@verifrax/kairoclasp": "^0.1.1",
    "@verifrax/limenward": "^0.1.1",
    "@verifrax/originseal": "^0.1.1",
    "@verifrax/root": "^0.0.2",
    "@verifrax/sigillarium": "^0.1.4",
    "@verifrax/validexor": "^0.1.1",
    "@verifrax/verifrax": "^0.1.4",
    "@verifrax/verifrax-api": "^0.0.4",
    "@verifrax/verifrax-profiles": "^0.1.1",
    "@verifrax/verifrax-spec": "^0.1.1",
    "@verifrax/verifrax-verify": "^0.1.6"
  }
}
